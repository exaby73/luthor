---
import type { HTMLAttributes } from 'astro/types';
import Icon from './user-components/Icon.astro';
import type { Icons } from './user-components/Icons';

interface Props {
	variant?: 'primary' | 'secondary' | 'minimal';
	link: string;
	icon?: undefined | keyof typeof Icons | { type: 'icon'; name: keyof typeof Icons } | { type: 'raw'; html: string };
	attrs?: Omit<HTMLAttributes<'a'>, 'href'>;
}

const { link, variant = 'primary', icon } = Astro.props;
const { class: customClass, ...attrs } = Astro.props.attrs || {};

const iconName = typeof icon === 'string' ? icon : icon?.type === 'icon' ? icon.name : undefined;
---

<a class:list={['sl-flex action', variant, customClass]} href={link} {...attrs}>
	<slot />
	{iconName && <Icon name={iconName} size="1.5rem" />}
	{typeof icon === 'object' && icon.type === 'raw' && <Fragment set:html={icon.html} />}
</a>

<style>
	.action {
		gap: 0.5em;
		align-items: center;
		justify-content: center;
		border-radius: 999rem;
		min-height: 2.75rem;
		padding: 0.65rem 1.125rem;
		color: var(--sl-color-white) !important;
		line-height: 1.1875;
		text-decoration: none;
		font-size: var(--sl-text-sm);
		text-align: center;
		white-space: normal;
		overflow-wrap: anywhere;
	}

	.action.primary {
		background: var(--sl-color-text-accent);
		color: var(--sl-color-black) !important;
	}

	.action.secondary {
		border: 1px solid;
	}

	.action.minimal {
		padding-inline: 0;
	}

	@media (min-width: 50rem) {
		.action {
			font-size: var(--sl-text-base);
			padding: 1rem 1.25rem;
		}
	}

	@media (max-width: 26rem) {
		.action {
			width: 100%;
		}
	}
</style>
