<label class="codegen-toggle">
  <input
    class="sr-only"
    x-data
    type="checkbox"
    role="switch"
    :checked="$store.codeGen.enabled"
    @change="$store.codeGen.toggle()"
  />
  <span class="track" aria-hidden="true">
    <span class="thumb" />
  </span>
  <span class="label">Code Generation</span>
</label>

<style>
  .codegen-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 2.75rem;
    color: var(--sl-color-gray-2);
    cursor: pointer;
    user-select: none;
  }

  .track {
    position: relative;
    display: inline-flex;
    align-items: center;
    width: 2.75rem;
    height: 1.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999rem;
    background-color: var(--sl-color-gray-5);
    transition:
      background-color 150ms ease,
      border-color 150ms ease;
  }

  .thumb {
    position: absolute;
    inset-inline-start: 0.125rem;
    width: 1.125rem;
    height: 1.125rem;
    border-radius: 50%;
    background-color: var(--sl-color-gray-1);
    transition:
      background-color 150ms ease,
      transform 150ms ease;
  }

  input:checked + .track,
  :global(:root[data-code-gen="true"]) input + .track {
    border-color: var(--sl-color-accent);
    background-color: var(--sl-color-accent);
  }

  input:checked + .track .thumb,
  :global(:root[data-code-gen="true"]) input + .track .thumb {
    background-color: var(--sl-color-white);
    transform: translateX(1.25rem);
  }

  :global([dir="rtl"]) input:checked + .track .thumb,
  :global([dir="rtl"][data-code-gen="true"]) input + .track .thumb {
    transform: translateX(-1.25rem);
  }

  input:focus-visible + .track {
    outline: 2px solid var(--sl-color-accent-high);
    outline-offset: 3px;
  }

  .label {
    font-size: var(--sl-text-sm);
    line-height: 1.4;
  }
</style>
